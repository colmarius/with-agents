---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BackNav from '@components/BackNav.astro';
import '../../../styles/global.css';

export async function getStaticPaths() {
  const posts = await getCollection('posts');

  const filteredPosts = import.meta.env.PROD
    ? posts.filter((post) => !post.data.draft)
    : posts;

  return filteredPosts.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}

type Props = CollectionEntry<'posts'>;

const post = Astro.props;
const { Content } = await render(post);
const canonicalUrl = new URL(
  `/posts/${post.id}`,
  Astro.site ?? Astro.url.origin,
).toString();
const slidesTitle = `${post.data.title} - Slides`;
const slidesDescription = `${post.data.description} Slide view.`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={slidesDescription} />
    <meta name="robots" content="noindex,follow" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={slidesTitle} />
    <meta property="og:description" content={slidesDescription} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
    <title>{slidesTitle}</title>
    <style>
      :global(.slide) {
        display: none;
      }

      :global(.slide.active) {
        display: block;
      }

      :global(.slide.active[data-layout='cover']) {
        display: flex;
        min-height: min(72vh, 46rem);
        align-items: center;
        justify-content: center;
      }

      :global(body.notes-visible .slide.active[data-layout='cover']) {
        display: block;
        min-height: auto;
      }

      :global(.slide.active[data-layout='image']) {
        display: flex;
        align-items: center;
        justify-content: center;
      }

      :global(body.notes-visible .slide.active[data-layout='image']) {
        display: block;
      }

      :global(.slide-main > blockquote:first-of-type) {
        border-left-color: #4f46e5;
        color: #0f172a;
        font-size: 1.35em;
        line-height: 1.35;
      }

      :global(.slide-main > blockquote:first-of-type small) {
        display: block;
        margin-top: 0.75rem;
        color: #64748b;
        font-size: 0.55em;
        font-weight: 400;
        line-height: 1.4;
      }

      :global(.slide[data-layout='cover'] .slide-main) {
        width: 100%;
        text-align: center;
      }

      :global(.slide[data-layout='cover'] .slide-main > h2) {
        margin-bottom: clamp(1.75rem, 4vw, 3.5rem);
        font-size: clamp(2.6rem, 6vw, 5rem);
        line-height: 1.05;
      }

      :global(.slide[data-layout='cover'] .slide-main > blockquote:first-of-type) {
        margin: 0 auto;
        border-left: 0;
        padding: 0;
        font-size: clamp(1.5rem, 3vw, 3rem);
      }

      :global(.slide[data-layout='cover'] .slide-main > blockquote:first-of-type p) {
        margin: 0;
      }

      :global(.slide[data-layout='cover'] .slide-main > blockquote:first-of-type small) {
        margin-top: clamp(1.5rem, 3vw, 2.5rem);
        font-size: 0.42em;
      }

      :global(.slide[data-message='small'] .slide-main > blockquote:first-of-type) {
        font-size: 1.05em;
      }

      :global(.slide[data-message='quiet'] .slide-main > blockquote:first-of-type) {
        border-left-color: #cbd5e1;
        color: #475569;
        font-size: 1.1em;
      }

      :global(.slide.slide-compact) {
        padding: 1.5rem;
      }

      :global(.slide[data-layout='text'] .slide-main) {
        font-size: 1.05rem;
      }

      :global(.slide[data-layout='text'] .slide-main :is(ul, ol)) {
        margin-top: 1rem;
      }

      :global(.slide[data-layout='split'] .slide-main) {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        gap: 2rem;
        align-items: center;
      }

      :global(.slide[data-layout='split'] .slide-main > h2) {
        grid-column: 1 / -1;
      }

      :global(.slide[data-layout='split'] .slide-main > blockquote:first-of-type) {
        grid-column: 1;
      }

      :global(.slide[data-layout='split'] .slide-main > :is(pre, table, figure, svg, .mermaid, p:has(img))) {
        grid-column: 2;
      }

      :global(.slide.active.slide-alignment-flow) {
        display: flex;
        min-height: min(72vh, 46rem);
        align-items: center;
        justify-content: center;
      }

      :global(body.notes-visible .slide.active.slide-alignment-flow) {
        display: block;
        min-height: auto;
      }

      :global(.slide.slide-alignment-flow .slide-main) {
        width: 100%;
      }

      :global(.slide.slide-alignment-flow .slide-main > h2) {
        max-width: 18ch;
        margin-right: auto;
        margin-left: auto;
        text-align: center;
        font-size: clamp(2.35rem, 5vw, 4.25rem);
        line-height: 1.05;
      }

      :global(.slide.slide-alignment-flow .slide-main > blockquote:first-of-type) {
        max-width: 34rem;
        margin: clamp(1.5rem, 3vw, 2.5rem) auto 0;
        border-left: 0;
        padding-left: 0;
        text-align: center;
        font-size: clamp(1.3rem, 2.5vw, 2.1rem);
      }

      :global(.slide.slide-alignment-flow .slide-main > blockquote:first-of-type p) {
        margin: 0;
      }

      :global(.slide .agent-speed-flow) {
        max-width: 46rem;
        margin: clamp(2rem, 4vw, 3.25rem) auto 0;
      }

      :global(.slide .agent-speed-flow__grid) {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.75rem;
        border-radius: 1.5rem;
        background: #111827;
        padding: 0.875rem;
        box-shadow: 0 1rem 2.5rem rgb(15 23 42 / 0.18);
      }

      :global(.slide .agent-speed-flow__card) {
        display: flex;
        min-height: 7.25rem;
        flex-direction: column;
        justify-content: center;
        border: 1px solid rgb(148 163 184 / 0.25);
        border-radius: 1rem;
        background: rgb(15 23 42 / 0.82);
        padding: 1rem;
        text-align: center;
      }

      :global(.slide .agent-speed-flow__card span) {
        color: #94a3b8;
        font-size: clamp(0.72rem, 1.2vw, 0.85rem);
        font-weight: 700;
        letter-spacing: 0.08em;
        line-height: 1.2;
        text-transform: uppercase;
      }

      :global(.slide .agent-speed-flow__card strong) {
        display: block;
        margin-top: 0.4rem;
        color: #f8fafc;
        font-size: clamp(1.25rem, 2.5vw, 1.8rem);
        font-weight: 750;
        line-height: 1.05;
      }

      :global(.slide .agent-speed-flow__arrow) {
        margin: 0.8rem 0 0.45rem;
        color: var(--color-primary-600);
        font-size: clamp(2rem, 4vw, 3rem);
        font-weight: 800;
        line-height: 1;
        text-align: center;
      }

      :global(.slide .agent-speed-flow figcaption) {
        margin: 0;
        color: #0f172a;
        font-size: clamp(1.35rem, 2.8vw, 2.2rem);
        font-weight: 750;
        line-height: 1.1;
        text-align: center;
      }

      :global(.slide .talk-figure) {
        max-width: 48rem;
        margin: clamp(1.5rem, 3vw, 2.5rem) auto 0;
      }

      :global(.slide .talk-path) {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: center;
        gap: 0.55rem;
        margin: clamp(1.5rem, 3vw, 2.5rem) 0 0;
      }

      :global(.slide .talk-node) {
        display: inline-flex;
        min-height: 3.25rem;
        align-items: center;
        justify-content: center;
        border: 1px solid #cbd5e1;
        border-radius: 999px;
        background: #fff;
        padding: 0.65rem 1rem;
        color: #334155;
        font-size: clamp(0.85rem, 1.6vw, 1rem);
        font-weight: 700;
        line-height: 1.15;
        text-align: center;
      }

      :global(.slide .talk-node--accent) {
        border-color: var(--color-primary-300);
        background: var(--color-primary-50);
        color: var(--color-primary-800);
      }

      :global(.slide .talk-arrow) {
        color: var(--color-primary-600);
        font-weight: 800;
      }

      :global(.slide .talk-grid) {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.85rem;
        margin: clamp(1.5rem, 3vw, 2.5rem) 0 0;
      }

      :global(.slide .talk-grid--3) {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      :global(.slide .talk-card) {
        border: 1px solid #e2e8f0;
        border-radius: 1rem;
        background: #f8fafc;
        padding: 1rem;
      }

      :global(.slide .talk-card--accent) {
        border-color: var(--color-primary-200);
        background: linear-gradient(180deg, var(--color-primary-50), #fff);
      }

      :global(.slide .talk-card--dark) {
        border-color: rgb(148 163 184 / 0.2);
        background: #111827;
        color: #f8fafc;
      }

      :global(.slide .talk-card span) {
        display: block;
        color: #64748b;
        font-size: 0.78rem;
        font-weight: 750;
        letter-spacing: 0.08em;
        line-height: 1.2;
        text-transform: uppercase;
      }

      :global(.slide .talk-card--dark span) {
        color: #94a3b8;
      }

      :global(.slide .talk-card strong) {
        display: block;
        margin-top: 0.45rem;
        color: #0f172a;
        font-size: clamp(1.1rem, 2vw, 1.45rem);
        line-height: 1.1;
      }

      :global(.slide .talk-card--dark strong) {
        color: #f8fafc;
      }

      :global(.slide .talk-card p) {
        margin: 0.55rem 0 0;
        color: #475569;
        font-size: clamp(0.9rem, 1.6vw, 1rem);
        line-height: 1.45;
      }

      :global(.slide .talk-card--dark p) {
        color: #cbd5e1;
      }

      :global(.slide .talk-stack) {
        display: grid;
        gap: 0.65rem;
        margin: clamp(1.5rem, 3vw, 2.5rem) 0 0;
      }

      :global(.slide .talk-stack__item) {
        display: grid;
        grid-template-columns: minmax(7rem, 0.4fr) minmax(0, 1fr);
        gap: 1rem;
        align-items: center;
        border: 1px solid #e2e8f0;
        border-radius: 0.9rem;
        background: #fff;
        padding: 0.85rem 1rem;
      }

      :global(.slide .talk-stack__item strong) {
        color: var(--color-primary-700);
        font-size: 1rem;
        line-height: 1.1;
      }

      :global(.slide .talk-stack__item span) {
        color: #334155;
        font-size: clamp(0.95rem, 1.8vw, 1.12rem);
        line-height: 1.25;
      }

      :global(.slide .talk-loop) {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0.75rem;
        margin: clamp(1.5rem, 3vw, 2.5rem) 0 0;
      }

      :global(.slide .talk-loop__item) {
        border: 1px solid var(--color-primary-200);
        border-radius: 1rem;
        background: var(--color-primary-50);
        padding: 1rem 0.75rem;
        color: var(--color-primary-900);
        font-size: clamp(0.95rem, 1.8vw, 1.15rem);
        font-weight: 750;
        line-height: 1.15;
        text-align: center;
      }

      :global(.slide .talk-note) {
        margin: 1.25rem auto 0;
        color: #475569;
        font-size: clamp(1rem, 1.8vw, 1.2rem);
        line-height: 1.4;
        text-align: center;
      }

      :global(.slide .talk-callout) {
        margin: clamp(1.5rem, 3vw, 2.5rem) auto 0;
        border-left: 4px solid var(--color-primary-500);
        border-radius: 0.9rem;
        background: var(--color-primary-50);
        padding: 1rem 1.25rem;
        color: #1e293b;
        font-size: clamp(1.05rem, 1.9vw, 1.25rem);
        line-height: 1.35;
      }

      @media (max-width: 48rem) {
        :global(.slide .talk-grid),
        :global(.slide .talk-grid--3),
        :global(.slide .talk-loop) {
          grid-template-columns: 1fr;
        }

        :global(.slide .talk-stack__item) {
          grid-template-columns: 1fr;
          gap: 0.25rem;
        }
      }

      :global(.slide[data-layout='image']) {
        aspect-ratio: 16 / 9;
        width: min(calc(100vw - 4rem), calc((100vh - 7rem) * 16 / 9));
        max-width: 90rem;
        overflow: hidden;
        border: 0;
        background: transparent;
        padding: 0;
        box-shadow: none;
      }

      :global(.slide[data-layout='image'] .slide-main) {
        width: 100%;
        height: 100%;
      }

      :global(.slide[data-layout='image'] .slide-main > h2) {
        position: absolute;
        width: 1px;
        height: 1px;
        margin: -1px;
        overflow: hidden;
        clip: rect(0 0 0 0);
        white-space: nowrap;
      }

      :global(.slide[data-layout='image'] .slide-main > p:has(> img:only-child)) {
        display: flex;
        width: 100%;
        height: 100%;
        align-items: center;
        justify-content: center;
        margin: 0;
      }

      :global(.slide[data-layout='image'] .slide-main img) {
        width: 100%;
        height: 100%;
        max-width: 100%;
        max-height: 100%;
        margin: 0;
        border: 0;
        border-radius: 0;
        background: transparent;
        box-shadow: none;
        object-fit: contain;
      }

      :global(body.image-only-slide-active:not(.notes-visible)) {
        background: #020617;
      }

      :global(body.image-only-slide-active:not(.notes-visible) .slide-topbar) {
        display: none;
      }

      :global(body.image-only-slide-active:not(.notes-visible) #slides-container) {
        top: 0;
        overflow: hidden;
        background: #020617;
        padding: 0;
      }

      :global(body.image-only-slide-active:not(.notes-visible) .slide-controls) {
        opacity: 0;
        transition: opacity 150ms ease;
      }

      :global(body.image-only-slide-active:not(.notes-visible) .slide-controls:hover),
      :global(body.image-only-slide-active:not(.notes-visible) .slide-controls:focus-within) {
        opacity: 1;
      }

      @media (max-width: 48rem) {
        :global(body.image-only-slide-active:not(.notes-visible) .slide-controls) {
          opacity: 1;
        }
      }

      :global(body.image-only-slide-active:not(.notes-visible) .slide.active[data-layout='image'].slide-image-only) {
        aspect-ratio: auto;
        width: 100vw;
        height: 100vh;
        height: 100dvh;
        max-width: none;
      }

      :global(body.notes-visible .slide[data-layout='image']) {
        aspect-ratio: auto;
        overflow: visible;
        border: 1px solid #e2e8f0;
        background: #fff;
        padding: 1.5rem;
        box-shadow: 0 1px 3px rgb(15 23 42 / 0.08);
      }

      :global(body.notes-visible .slide[data-layout='image'] .slide-main),
      :global(body.notes-visible .slide[data-layout='image'] .slide-main > p:has(> img:only-child)) {
        height: auto;
      }

      :global(body.notes-visible .slide[data-layout='image'] .slide-main img) {
        height: auto;
      }

      :global(.slide-notes) {
        display: none;
        margin-top: 2rem;
        border-top: 1px solid #e2e8f0;
        padding-top: 1.5rem;
      }

      :global(body.notes-visible .slide-notes) {
        display: block;
      }

      :global(#source-appendices) {
        display: none;
      }

      :global(body.notes-visible #source-appendices:not(:empty)) {
        display: block;
      }

      :global(.slide pre:has(> code.language-mermaid)),
      :global(.slide pre:has(> code.lang-mermaid)),
      :global(.slide pre[data-language="mermaid"]),
      :global(.slide pre[class*="language-mermaid"]),
      :global(.slide-appendix pre:has(> code.language-mermaid)),
      :global(.slide-appendix pre:has(> code.lang-mermaid)),
      :global(.slide-appendix pre[data-language="mermaid"]),
      :global(.slide-appendix pre[class*="language-mermaid"]) {
        display: none;
      }

      :global(.slide pre > code.language-mermaid),
      :global(.slide pre > code.lang-mermaid),
      :global(.slide pre[data-language="mermaid"] > code),
      :global(.slide pre[class*="language-mermaid"] > code),
      :global(.slide-appendix pre > code.language-mermaid),
      :global(.slide-appendix pre > code.lang-mermaid),
      :global(.slide-appendix pre[data-language="mermaid"] > code),
      :global(.slide-appendix pre[class*="language-mermaid"] > code) {
        display: none;
      }

      #source {
        display: none;
      }

      #appendix-link[hidden] {
        display: none;
      }

      @media print {
        :global(body) {
          background: #fff !important;
          overflow: visible !important;
        }

        :global(.slide-topbar),
        :global(.slide-controls) {
          display: none !important;
        }

        #slides-container {
          position: static !important;
          overflow: visible !important;
          padding: 0 !important;
        }

        :global(.slide),
        :global(.slide.active) {
          display: block !important;
          max-width: none !important;
          min-height: auto !important;
          margin: 0 0 2rem !important;
          break-after: page;
          box-shadow: none !important;
        }

        :global(.slide-notes),
        :global(#source-appendices:not(:empty)) {
          display: block !important;
        }

        :global(#source-appendices:not(:empty)) {
          break-before: page;
          margin-top: 0 !important;
        }
      }
    </style>
  </head>
  <body class="bg-white text-slate-900 overflow-hidden">
    <div
      class="slide-topbar fixed top-0 left-0 right-0 h-14 bg-white border-b border-slate-200 flex items-center justify-between px-4 sm:px-8 z-50"
    >
      <BackNav href={`/posts/${post.id}`} label="Back to Post" />
      <div
        class="text-sm font-semibold text-slate-900 flex-1 text-center truncate px-4"
      >
        {post.data.title}
      </div>
      <div class="flex items-center justify-end gap-2 text-sm text-slate-600">
        <a
          id="appendix-link"
          href="#source-appendices"
          hidden
          class="rounded-md border border-slate-200 bg-white px-2 py-1 text-slate-700 transition-colors hover:bg-slate-50 hover:text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-600/50"
        >
          Sources
        </a>
        <button
          id="notes-btn"
          type="button"
          aria-pressed="false"
          class="rounded-md border border-slate-200 bg-white px-2 py-1 text-slate-700 transition-colors hover:bg-slate-50 hover:text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-600/50"
        >
          Notes
        </button>
        <div class="min-w-16 text-right" aria-live="polite">
          <span id="current">1</span> / <span id="total">1</span>
        </div>
      </div>
    </div>

    <div
      id="slides-container"
      class="fixed top-14 left-0 right-0 bottom-0 overflow-y-auto p-4 sm:p-8"
    >
      <noscript>
        <div class="mx-auto max-w-3xl bg-white border border-slate-200 rounded-lg p-8 sm:p-12 shadow-sm">
          <h1 class="text-2xl font-semibold text-slate-900 mb-4">
            JavaScript is required for slide navigation
          </h1>
          <p class="text-slate-700">
            This generated slide view needs JavaScript. You can still read the
            source article:
            <a class="text-indigo-700 underline" href={`/posts/${post.id}`}>
              {post.data.title}
            </a>.
          </p>
        </div>
      </noscript>
      <div id="source-appendices" class="mx-auto max-w-3xl space-y-6"></div>
    </div>

    <div id="source">
      <Content />
    </div>

    <div class="slide-controls fixed bottom-4 sm:bottom-8 right-4 sm:right-8 flex gap-2 z-50">
      <button
        class="w-10 h-10 sm:w-12 sm:h-12 bg-white border border-slate-200 rounded-lg text-slate-600 cursor-pointer flex items-center justify-center text-xl transition-all hover:bg-slate-50 hover:text-slate-900 hover:border-slate-300 disabled:opacity-30 disabled:cursor-not-allowed"
        id="prev-btn"
        aria-label="Previous slide"
      >
        ←
      </button>
      <button
        class="w-10 h-10 sm:w-12 sm:h-12 bg-white border border-slate-200 rounded-lg text-slate-600 cursor-pointer flex items-center justify-center text-xl transition-all hover:bg-slate-50 hover:text-slate-900 hover:border-slate-300 disabled:opacity-30 disabled:cursor-not-allowed"
        id="next-btn"
        aria-label="Next slide"
      >
        →
      </button>
    </div>

    <script>
      import { mermaidConfig } from '@scripts/mermaid-config';

      const mermaidUrl =
        'https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs';
      const importMermaid = new Function('url', 'return import(url)') as (
        url: string,
      ) => Promise<
        typeof import('https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs')
      >;
      const slideClasses =
        'slide prose-slide mx-auto max-w-3xl bg-white border border-slate-200 rounded-lg p-8 sm:p-12 shadow-sm';
      const appendixClasses =
        'slide-appendix prose-slide bg-white border border-slate-200 rounded-lg p-8 sm:p-12 shadow-sm';
      const sourceHeadings = new Set(['sources', 'sources used']);
      const validSlideLayouts = new Set([
        'message',
        'visual',
        'image',
        'text',
        'split',
        'cover',
      ]);
      const validMessageSizes = new Set(['normal', 'small', 'quiet']);

      type SlideConfig = {
        layout?: string;
        message?: string;
        classTokens: string[];
      };

      let currentIndex = 0;
      let totalSlides = 0;

      const getRequiredElement = <T extends HTMLElement>(id: string) => {
        const element = document.getElementById(id);

        if (!element) {
          throw new Error(`Missing expected slide element: #${id}`);
        }

        return element as T;
      };

      const normalizeHeadingText = (text: string) =>
        text.replace(/\s+/g, ' ').trim().toLowerCase();

      const emptySlideConfig = (): SlideConfig => ({ classTokens: [] });

      const parseSlideConfig = (text: string | null | undefined) => {
        const trimmed = text?.trim() ?? '';
        if (!trimmed.startsWith('slide:')) return null;

        const config = emptySlideConfig();
        const body = trimmed.slice('slide:'.length).trim();

        for (const rawLine of body.split(/\r?\n/)) {
          const line = rawLine.trim();
          if (!line) continue;

          const match = line.match(/^([a-z]+)\s*:\s*(.+)$/i);
          if (!match) continue;

          const [, key, rawValue] = match;
          const value = rawValue.trim();

          if (key === 'layout' && validSlideLayouts.has(value)) {
            config.layout = value;
          } else if (key === 'message' && validMessageSizes.has(value)) {
            config.message = value;
          } else if (key === 'class') {
            config.classTokens.push(
              ...value
                .split(/\s+/)
                .filter((token) => /^[a-z0-9_-]+$/i.test(token)),
            );
          }
        }

        return config;
      };

      const mergeSlideConfig = (target: SlideConfig, source: SlideConfig) => {
        target.layout = source.layout ?? target.layout;
        target.message = source.message ?? target.message;
        target.classTokens.push(...source.classTokens);
      };

      const applySlideConfig = (slide: HTMLElement, config: SlideConfig) => {
        slide.dataset.layout = config.layout ?? 'message';
        slide.dataset.message = config.message ?? 'normal';

        for (const token of new Set(config.classTokens)) {
          slide.classList.add(`slide-${token}`);
        }
      };

      const isElement = (
        node: Node | null | undefined,
        tagName: string,
      ): node is Element =>
        node instanceof Element &&
        node.tagName.toLowerCase() === tagName;

      const isMeaningfulNode = (node: Node) => {
        if (node.nodeType === Node.ELEMENT_NODE) return true;
        return (
          node.nodeType === Node.TEXT_NODE &&
          (node.textContent ?? '').trim() !== ''
        );
      };

      const firstMeaningfulIndex = (nodes: Node[], startIndex = 0) => {
        for (let index = startIndex; index < nodes.length; index++) {
          if (isMeaningfulNode(nodes[index])) return index;
        }
        return -1;
      };

      const isNotesDelimiter = (node: Node) =>
        (isElement(node, 'p') &&
          normalizeHeadingText(node.textContent ?? '') === 'notes:') ||
        (node.nodeType === Node.COMMENT_NODE &&
          ['notes', 'notes:'].includes(normalizeHeadingText(node.textContent ?? '')));

      const findNotesDelimiterIndex = (nodes: Node[], startIndex: number) => {
        for (let index = startIndex; index < nodes.length; index++) {
          if (isNotesDelimiter(nodes[index])) return index;
        }

        return -1;
      };

      const getSlideConfig = (nodes: Node[], headingIndex: number) => {
        const config = emptySlideConfig();
        const configIndexes = new Set<number>();

        for (let index = headingIndex + 1; index < nodes.length; index++) {
          const node = nodes[index];

          if (node.nodeType === Node.TEXT_NODE && !isMeaningfulNode(node)) {
            continue;
          }

          if (node.nodeType === Node.COMMENT_NODE) {
            const parsed = parseSlideConfig(node.textContent);
            if (parsed) {
              mergeSlideConfig(config, parsed);
              configIndexes.add(index);
              continue;
            }
          }

          if (isMeaningfulNode(node)) break;
        }

        return { config, configIndexes };
      };

      const looksLikeMermaid = (text: string) => {
        const trimmed = text.trim();
        return (
          trimmed.startsWith('flowchart') ||
          trimmed.startsWith('graph') ||
          trimmed.startsWith('sequenceDiagram') ||
          trimmed.startsWith('classDiagram') ||
          trimmed.startsWith('stateDiagram') ||
          trimmed.startsWith('erDiagram') ||
          trimmed.startsWith('journey') ||
          trimmed.startsWith('gantt') ||
          trimmed.startsWith('pie') ||
          trimmed.startsWith('gitGraph')
        );
      };

      const isMermaidCode = (code: Element) => {
        const className = code.className || '';
        const parent = code.closest('pre');
        return (
          /(?:^|\s)(?:language|lang)-mermaid(?:\s|$)/.test(className) ||
          parent?.dataset.language === 'mermaid' ||
          parent?.className.includes('language-mermaid') ||
          looksLikeMermaid(code.textContent || '')
        );
      };

      const isTextDiagramCode = (code: Element) => {
        const className = code.className || '';
        const text = code.textContent || '';
        return (
          /(?:^|\s)(?:language|lang)-(?:text|plaintext|diagram|ascii)(?:\s|$)/.test(
            className,
          ) || /[╭╮╰╯┌┐└┘─│├┤┬┴┼→←↑↓]/.test(text)
        );
      };

      const isVisualCodeBlock = (element: Node) => {
        if (!isElement(element, 'pre')) return false;
        const code = element.querySelector('code');
        if (!code) return false;
        return isMermaidCode(code) || isTextDiagramCode(code);
      };

      const nodeContainsOnlyImage = (node: Node): boolean => {
        if (node.nodeType === Node.TEXT_NODE) {
          return (node.textContent ?? '').trim() === '';
        }

        if (!(node instanceof Element)) return false;

        const element = node;
        if (element.tagName.toLowerCase() === 'img') return true;
        if (element.tagName.toLowerCase() !== 'a') return false;

        const childNodes = Array.from(element.childNodes).filter((child) =>
          isMeaningfulNode(child),
        );
        return childNodes.length > 0 && childNodes.every(nodeContainsOnlyImage);
      };

      const isImageParagraph = (element: Node) => {
        if (!isElement(element, 'p')) return false;
        const childNodes = Array.from(element.childNodes).filter((child) =>
          isMeaningfulNode(child),
        );
        return childNodes.length > 0 && childNodes.every(nodeContainsOnlyImage);
      };

      const isVisualBlock = (node: Node) => {
        if (!(node instanceof Element)) return false;
        const tagName = node.tagName.toLowerCase();
        return (
          isImageParagraph(node) ||
          tagName === 'figure' ||
          tagName === 'svg' ||
          tagName === 'table' ||
          isVisualCodeBlock(node)
        );
      };

      const createSlide = (index: number, headingText: string) => {
        const slide = document.createElement('section');
        slide.className = slideClasses;
        slide.dataset.index = String(index);
        slide.id = `slide-${index + 1}`;
        slide.setAttribute('aria-roledescription', 'slide');
        slide.setAttribute('aria-label', headingText || `Slide ${index + 1}`);
        return slide;
      };

      const createSectionFragment = (
        source: HTMLElement,
        heading: HTMLHeadingElement,
        nextHeading?: HTMLHeadingElement,
      ) => {
        const range = document.createRange();
        range.setStartBefore(heading);

        if (nextHeading) {
          range.setEndBefore(nextHeading);
        } else {
          range.setEndAfter(source.lastChild || heading);
        }

        return range.cloneContents();
      };

      const buildLegacySlide = (
        fragment: DocumentFragment,
        index: number,
        headingText: string,
      ) => {
        const slide = createSlide(index, headingText);
        slide.dataset.slideMode = 'legacy';
        applySlideConfig(slide, emptySlideConfig());
        slide.appendChild(fragment);
        return slide;
      };

      const buildStructuredSlide = (
        fragment: DocumentFragment,
        index: number,
        headingText: string,
      ) => {
        const nodes = Array.from(fragment.childNodes);
        const headingIndex = firstMeaningfulIndex(nodes);
        const { config, configIndexes } = getSlideConfig(nodes, headingIndex);
        const quoteIndex = firstMeaningfulIndex(nodes, headingIndex + 1);
        const notesIndex = findNotesDelimiterIndex(nodes, headingIndex + 1);
        const firstBodyNode = nodes[quoteIndex];
        const startsWithBlockquote = isElement(firstBodyNode, 'blockquote');
        const supportsVisualOnly = ['visual', 'image'].includes(
          config.layout ?? '',
        );
        const startsWithVisual = firstBodyNode
          ? isVisualBlock(firstBodyNode)
          : false;

        if (
          headingIndex === -1 ||
          (notesIndex === -1 &&
            !startsWithBlockquote &&
            !(supportsVisualOnly && startsWithVisual))
        ) {
          return buildLegacySlide(fragment, index, headingText);
        }

        const mainIndexes = new Set([headingIndex]);
        let scanIndex = quoteIndex + 1;

        if (startsWithBlockquote || (supportsVisualOnly && startsWithVisual)) {
          mainIndexes.add(quoteIndex);
        }

        if (notesIndex !== -1) {
          mainIndexes.clear();
          mainIndexes.add(headingIndex);

          for (let nodeIndex = headingIndex + 1; nodeIndex < notesIndex; nodeIndex++) {
            if (configIndexes.has(nodeIndex)) continue;
            if (isMeaningfulNode(nodes[nodeIndex])) mainIndexes.add(nodeIndex);
          }
        }

        while (notesIndex === -1 && scanIndex < nodes.length) {
          const node = nodes[scanIndex];

          if (!isMeaningfulNode(node)) {
            scanIndex++;
            continue;
          }

          if (!isVisualBlock(node)) break;

          mainIndexes.add(scanIndex);
          scanIndex++;
        }

        const slide = createSlide(index, headingText);
        const main = document.createElement('div');
        const notes = document.createElement('aside');
        let notesHasContent = false;

        slide.dataset.slideMode = 'structured';
        applySlideConfig(slide, config);
        main.className = 'slide-main';
        notes.className = 'slide-notes';
        notes.setAttribute('aria-label', `Notes for ${headingText || 'slide'}`);

        for (const [nodeIndex, node] of nodes.entries()) {
          if (mainIndexes.has(nodeIndex)) {
            main.appendChild(node);
          } else if (
            nodeIndex > headingIndex &&
            nodeIndex !== notesIndex &&
            !configIndexes.has(nodeIndex) &&
            isMeaningfulNode(node)
          ) {
            notesHasContent = true;
            notes.appendChild(node);
          }
        }

        slide.appendChild(main);

        if (notesHasContent) {
          const notesHeading = document.createElement('h3');
          notesHeading.textContent = 'Notes';
          notes.prepend(notesHeading);
          slide.appendChild(notes);
        }

        return slide;
      };

      const appendAppendix = (
        fragment: DocumentFragment,
        headingText: string,
      ) => {
        const appendices = getRequiredElement<HTMLDivElement>('source-appendices');
        const appendix = document.createElement('section');
        appendix.className = appendixClasses;
        appendix.setAttribute('aria-label', `${headingText} appendix`);
        appendix.appendChild(fragment);
        appendices.appendChild(appendix);
      };

      const insertSlide = (container: HTMLElement, slide: HTMLElement) => {
        const appendices = getRequiredElement<HTMLDivElement>('source-appendices');
        container.insertBefore(slide, appendices);
      };

      const splitIntoSlides = () => {
        const source = getRequiredElement<HTMLDivElement>('source');
        const container = getRequiredElement<HTMLDivElement>('slides-container');
        const appendices = getRequiredElement<HTMLDivElement>('source-appendices');
        const headings = Array.from(
          source.querySelectorAll<HTMLHeadingElement>('h2'),
        );
        let slideCount = 0;

        appendices.replaceChildren();

        if (headings.length === 0) {
          const slide = createSlide(0, document.title.replace(/ - Slides$/, ''));
          slide.dataset.slideMode = 'legacy';
          Array.from(source.children).forEach((child) => {
            slide.appendChild(child.cloneNode(true));
          });
          insertSlide(container, slide);
          return 1;
        }

        for (const [headingIndex, heading] of headings.entries()) {
          const headingText = heading.textContent?.trim() ?? '';
          const fragment = createSectionFragment(
            source,
            heading,
            headings[headingIndex + 1],
          );

          if (sourceHeadings.has(normalizeHeadingText(headingText))) {
            appendAppendix(fragment, headingText);
            continue;
          }

          const slide = buildStructuredSlide(fragment, slideCount, headingText);
          insertSlide(container, slide);
          slideCount++;
        }

        return slideCount;
      };

      const updateSlideMetadata = () => {
        const slides = Array.from(document.querySelectorAll<HTMLElement>('.slide'));
        totalSlides = slides.length;
        getRequiredElement<HTMLElement>('total').textContent = String(totalSlides);

        slides.forEach((slide, index) => {
          const heading = slide.querySelector('h1, h2, h3');
          const label = heading?.textContent?.trim() || `Slide ${index + 1}`;
          slide.dataset.index = String(index);
          slide.id = `slide-${index + 1}`;
          slide.setAttribute(
            'aria-label',
            `${label} (${index + 1} of ${totalSlides})`,
          );
        });
      };

      const getHashSlideIndex = () => {
        const match = window.location.hash.match(/^#?(\d+)$/);
        if (!match) return null;

        const parsed = Number.parseInt(match[1], 10) - 1;
        if (Number.isNaN(parsed) || parsed < 0 || parsed >= totalSlides) {
          return null;
        }

        return parsed;
      };

      const replaceHashForCurrentSlide = () => {
        if (totalSlides === 0) return;

        const url = new URL(window.location.href);
        url.hash = String(currentIndex + 1);
        window.history.replaceState(window.history.state, '', url);
      };

      const setNotesVisible = (isVisible: boolean, updateUrl = true) => {
        const notesButton = getRequiredElement<HTMLButtonElement>('notes-btn');
        document.body.classList.toggle('notes-visible', isVisible);
        notesButton.setAttribute('aria-pressed', String(isVisible));
        notesButton.textContent = isVisible ? 'Hide notes' : 'Notes';

        if (!updateUrl) return;

        const url = new URL(window.location.href);
        if (isVisible) {
          url.searchParams.set('notes', '1');
        } else {
          url.searchParams.delete('notes');
        }
        window.history.replaceState(window.history.state, '', url);
      };

      const renderMermaidInline = async (root: Document | Element = document) => {
        const selectors = [
          'pre > code.language-mermaid',
          'pre > code.lang-mermaid',
          'pre[data-language="mermaid"] > code',
          'pre[class*="language-mermaid"] > code',
        ].join(', ');

        let codes = Array.from(root.querySelectorAll<Element>(selectors));

        if (codes.length === 0) {
          codes = Array.from(root.querySelectorAll<Element>('pre > code')).filter(
            isMermaidCode,
          );
        }

        for (const code of codes) {
          const pre = code.closest('pre');
          const div = document.createElement('div');
          div.className = 'mermaid mermaid-loading';
          div.textContent = code.textContent || '';
          pre?.replaceWith(div);
        }

        const mermaidElements = Array.from(root.querySelectorAll('.mermaid')).filter(
          (element) => element.getAttribute('data-processed') !== 'true',
        );

        if (mermaidElements.length === 0) return;

        const { default: mermaid } = await importMermaid(mermaidUrl);
        mermaid.initialize(mermaidConfig);
        await mermaid.run({ nodes: mermaidElements });

        root.querySelectorAll('.mermaid-loading').forEach((element) => {
          element.classList.remove('mermaid-loading');
        });
      };

      const renderAllMermaid = async () => {
        const renderRoots = document.querySelectorAll<HTMLElement>(
          '.slide, .slide-appendix',
        );

        for (const root of renderRoots) {
          if (root.dataset.mermaidRendered) continue;
          await renderMermaidInline(root);
          root.dataset.mermaidRendered = 'true';
        }
      };

      const updateSlide = async () => {
        const slides = Array.from(document.querySelectorAll<HTMLElement>('.slide'));

        slides.forEach((slide, index) => {
          slide.classList.toggle('active', index === currentIndex);
        });

        getRequiredElement<HTMLElement>('current').textContent = String(
          totalSlides === 0 ? 0 : currentIndex + 1,
        );
        getRequiredElement<HTMLButtonElement>('prev-btn').disabled = currentIndex === 0;
        getRequiredElement<HTMLButtonElement>('next-btn').disabled =
          totalSlides === 0 || currentIndex === totalSlides - 1;

        replaceHashForCurrentSlide();

        const currentSlide = slides[currentIndex];
        document.body.classList.toggle(
          'image-only-slide-active',
          currentSlide?.matches("[data-layout='image'].slide-image-only") ?? false,
        );

        if (currentSlide && !currentSlide.dataset.mermaidRendered) {
          await renderMermaidInline(currentSlide);
          currentSlide.dataset.mermaidRendered = 'true';
        }
      };

      const nextSlide = () => {
        if (currentIndex >= totalSlides - 1) return false;
        currentIndex++;
        void updateSlide();
        return true;
      };

      const prevSlide = () => {
        if (currentIndex <= 0) return false;
        currentIndex--;
        void updateSlide();
        return true;
      };

      const focusedInteractiveElement = () => {
        const activeElement = document.activeElement;
        if (!activeElement || activeElement === document.body) return false;
        return Boolean(
          activeElement.closest(
            'a, button, input, textarea, select, summary, [contenteditable="true"], [contenteditable=""], [role="button"], [role="link"], [role="textbox"]',
          ),
        );
      };

      const hasModifierKey = (event: KeyboardEvent) =>
        event.altKey || event.ctrlKey || event.metaKey || event.shiftKey;

      const handleKeydown = (event: KeyboardEvent) => {
        if (focusedInteractiveElement() || hasModifierKey(event)) return;

        let didNavigate = false;

        if (event.key === 'n' || event.key === 'N') {
          const isVisible = document.body.classList.contains('notes-visible');
          setNotesVisible(!isVisible);
          return;
        }

        if (event.key === 'ArrowLeft' || event.key === 'ArrowUp') {
          didNavigate = prevSlide();
        } else if (
          event.key === 'ArrowRight' ||
          event.key === 'ArrowDown' ||
          event.key === ' '
        ) {
          didNavigate = nextSlide();
        }

        if (didNavigate) event.preventDefault();
      };

      const initialize = async () => {
        splitIntoSlides();
        updateSlideMetadata();

        const initialSlide = getHashSlideIndex();
        if (initialSlide !== null) currentIndex = initialSlide;

        setNotesVisible(
          new URLSearchParams(window.location.search).get('notes') === '1',
          false,
        );

        const appendixLink = getRequiredElement<HTMLAnchorElement>('appendix-link');
        const appendices = getRequiredElement<HTMLDivElement>('source-appendices');
        appendixLink.hidden = appendices.children.length === 0;

        await updateSlide();
        await renderAllMermaid();
      };

      getRequiredElement<HTMLButtonElement>('prev-btn').addEventListener('click', () => {
        prevSlide();
      });
      getRequiredElement<HTMLButtonElement>('next-btn').addEventListener('click', () => {
        nextSlide();
      });
      getRequiredElement<HTMLButtonElement>('notes-btn').addEventListener('click', () => {
        const isVisible = document.body.classList.contains('notes-visible');
        setNotesVisible(!isVisible);
      });
      getRequiredElement<HTMLAnchorElement>('appendix-link').addEventListener(
        'click',
        (event: MouseEvent) => {
          event.preventDefault();
          setNotesVisible(true);
          getRequiredElement<HTMLDivElement>('source-appendices').scrollIntoView({
            block: 'start',
          });
        },
      );
      document.addEventListener('keydown', handleKeydown);
      window.addEventListener('hashchange', () => {
        const hashIndex = getHashSlideIndex();
        if (hashIndex === null || hashIndex === currentIndex) return;
        currentIndex = hashIndex;
        void updateSlide();
      });
      window.addEventListener('beforeprint', () => {
        void renderAllMermaid();
      });

      initialize();
    </script>
  </body>
</html>
