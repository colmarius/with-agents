---
import codingResources from '../../data/resources/coding-with-agents.json';
import Layout from '../../layouts/Layout.astro';
---

<Layout title="With Agents – Resources">
  <div class="max-w-4xl mx-auto">
    <h1 class="text-4xl md:text-5xl font-light mb-4 text-gray-900">
      Resources
    </h1>
    <p class="text-xl text-gray-600 mb-12 font-light leading-relaxed">
      Curated media and summaries for learning how experienced teams use coding agents.
    </p>

    <a href="/resources/coding-with-agents" class="block rounded-xl border border-gray-200 p-8 hover:shadow-lg transition-all duration-200 bg-white hover:border-gray-300 group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-600/50 focus-visible:ring-offset-2">
      <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
        <div>
          <p class="mb-3 text-sm font-medium uppercase tracking-wide text-indigo-600">
            Resource hub
          </p>
          <h2 class="text-3xl font-light text-gray-900 mb-3">Coding with Agents</h2>
          <p class="text-gray-600 leading-relaxed max-w-2xl">
            Podcasts, videos, and articles on AI-powered development workflows, with summaries for quick triage.
          </p>
        </div>
        <div class="text-sm text-gray-500 font-medium md:text-right">
          {codingResources.length} resources →
        </div>
      </div>
    </a>
  </div>
</Layout>
